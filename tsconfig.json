{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "paths": {
      "#imports": [
        "./.nuxt/imports.d.ts"
      ],
      "~/*": [
        "./*",
        "./.nuxt/*"
      ],
      "@/*": [
        "./components/*",
        "./pages/*"
      ],
      "~~/*": [
        "./*",
        "./.nuxt/*"
      ],
      "@@/*": [
        "./components/*",
        "./pages/*"
      ],
      "assets/*": [
        "./assets/*"
      ],
      "#app": [
        "./node_modules/nuxt/dist/app"
      ],
      "#app/*": [
        "./node_modules/nuxt/dist/app/*"
      ],
      "vue-demi": [
        "./node_modules/nuxt/dist/app/compat/vue-demi"
      ],
      "#ui": [
        "./node_modules/@nuxt/ui/dist/runtime/types/index"
      ],
      "#components": [
        "./.nuxt/components"
      ]
    }
  }
}
